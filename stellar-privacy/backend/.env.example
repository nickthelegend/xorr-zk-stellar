# ── Delivery layer (existing) ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster/...
PORT=8787

# ── Custodial pay-to-email identity layer (NEW) ────────────────────────────
# Provider: privy (recommended — keys held in Privy's TEE, signed via raw_sign)
#           | selfhosted (keys derived locally from KMS_MASTER below).
IDENTITY_PROVIDER=privy

# Privy (https://dashboard.privy.io). The App secret is sensitive — keep it here
# only, never commit, and rotate if it leaks.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# KMS_MASTER is used ONLY when IDENTITY_PROVIDER=selfhosted. It is the single
# root secret from which every self-hosted user's shielded + Stellar keys derive
# — treat it like an HSM root. Generate a fresh one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KMS_MASTER=REPLACE_ME_WITH_32_RANDOM_BYTES_BASE64

# Pepper for the salted email hash (the only email-derived value persisted).
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
EMAIL_PEPPER=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# Shared HMAC secret between the Next app and this backend. The Next app signs
# short-lived service tokens (HS256) with it; this backend verifies them. Must
# match SERVICE_SECRET in xorr-core's env. ≥16 chars.
SERVICE_SECRET=REPLACE_ME_SHARED_WITH_NEXT_APP

# Where the claim link points (must be the app origin — no open redirect).
APP_URL=http://localhost:3000

# ── Email transport ────────────────────────────────────────────────────────
# console (default, logs the email) | smtp | resend
EMAIL_TRANSPORT=console
# Resend (https://resend.com) — set the key and EMAIL_TRANSPORT=resend to send.
RESEND_API_KEY=
# Verified-domain sender to email anyone; onboarding@resend.dev = test mode
# (delivers only to your own Resend account email).
EMAIL_FROM=XORR <onboarding@resend.dev>
# SMTP_URL=smtp://user:pass@smtp.example.com:587

# ── Stellar account provisioning (claim) ───────────────────────────────────
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Classic USDC asset for the recipient withdraw trustline (best-effort).
USDC_CODE=USDC
USDC_ISSUER=GAVKGXALNNSW35QZKLVYL5CNORBEGHBF7KMHEEVW5LEHT5XVNQZDD6KI
